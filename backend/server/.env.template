# FloatChat-AI Backend — Environment Configuration Template

## Database & Storage

# MongoDB connection string
# Format: mongodb://[username:password@]host[:port]/[database]
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=floatchat_ai

# ChromaDB persistence directory (for semantic/vector search)
# Path is relative to the backend/server directory
CHROMA_PERSIST_DIR=../../chroma_data

## LLM Configuration

# OpenRouter API Key
# GET YOUR KEY: https://openrouter.ai
# Format: sk-or-v1-YOUR-LONG-KEY-HERE
# 🔑 REQUIRED: This is mandatory for LLM features to work
OPENROUTER_API_KEY=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

# LLM Model selection via OpenRouter
# Available models:
#   qwen/qwen3.5-397b-a17b    (Default, recommended) — Fast, cost-effective
#   openai/gpt-4-turbo        (Powerful) — Slower, higher cost
#   anthropic/claude-3-opus   (Advanced reasoning) — Expensive
#   meta-llama/llama-2-70b    (Open source)
LLM_MODEL=qwen/qwen3.5-397b-a17b

# LLM Base URL (OpenRouter API endpoint)
# Format: https://openrouter.ai/api/v1 (for OpenRouter)
#         https://api.openai.com/v1 (for OpenAI direct)
LLM_BASE_URL=https://openrouter.ai/api/v1

## Server Configuration

# Backend server port
PORT=3001

# CORS and security (optional)
# Set allowed origins for requests from frontend
# NODE_ENV=production
# CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

## Optional Development Settings

# Enable detailed logging
# DEBUG=floatchat:*

# Enable test mode (falls back without LLM if key not set)
